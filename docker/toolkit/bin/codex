#!/bin/sh
TOOLKIT="${MEMOH_TOOLKIT_DIR:-/opt/memoh/toolkit}"
CODEX="$TOOLKIT/acp/lib/node_modules/@openai/codex/bin/codex.js"
TOOLKIT_CA_BUNDLE="$TOOLKIT/certs/ca-certificates.crt"

if [ -z "${SSL_CERT_FILE:-}" ] && [ -f "$TOOLKIT_CA_BUNDLE" ]; then
  export SSL_CERT_FILE="$TOOLKIT_CA_BUNDLE"
fi

fallback_codex() {
  old_ifs="$IFS"
  IFS=:
  for dir in $PATH; do
    IFS="$old_ifs"
    [ -n "$dir" ] || dir=.
    case "$dir" in
      "$TOOLKIT/bin") ;;
      *)
        if [ -x "$dir/codex" ]; then
          exec "$dir/codex" "$@"
        fi
        ;;
    esac
    IFS=:
  done
  IFS="$old_ifs"
}

if [ ! -f "$CODEX" ]; then
  fallback_codex "$@"
  echo "codex is not installed in the Memoh workspace toolkit and no fallback codex command was found: $CODEX" >&2
  exit 127
fi
exec "$TOOLKIT/bin/node" "$CODEX" "$@"
