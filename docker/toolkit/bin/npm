#!/bin/sh
TOOLKIT=/opt/memoh/toolkit
if ls /lib/ld-musl-*.so.1 >/dev/null 2>&1; then
  NODEDIR="$TOOLKIT/node-musl"
  export LD_LIBRARY_PATH="$NODEDIR/runtime-lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
else
  NODEDIR="$TOOLKIT/node-glibc"
fi
export PATH="$NODEDIR/bin:$PATH"
exec "$NODEDIR/bin/npm" "$@"
